programa {
  funcao inicio() {
    inteiro piramide
    
    
    


    escreva("Digite um número inteiro para definir a altura da piramide: ")
    leia(piramide)

    para(inteiro i = piramide; i >= 1; i--){
      para(inteiro j = 1; j <= i; j++){
        escreva("*")
      }
        escreva("\n")
    }
   }
}
    
    
  

