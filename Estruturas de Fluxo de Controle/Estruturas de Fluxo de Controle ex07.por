programa {
  funcao inicio() {
  inteiro numero1
  inteiro numero2

    escreva ("Digite um número para a letra A: ")
    leia (numero1)
    escreva ("Digite um número para a letra B: ")
    leia (numero2)


      se ( numero1 > numero2){
        escreva ("A > B")
    }
      senao se (numero2 > numero1){
        escreva ("B > A")
    }
      senao {escreva("A == B")}
    } 

  }
}
