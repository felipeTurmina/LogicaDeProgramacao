programa {
  funcao inicio() {

   inteiro idade1
   inteiro idade2


    escreva ("Digite a idade da pessoa que nasceu antes: ")
    leia (idade1)
    escreva ("escreva a idadade da pessoa mais nova: ")
    leia (idade2)


    escreva ("A idade da pessoa mais velha é de ", 2026 - idade1, " anos \n")
    escreva ("A idade da pessoa mais nova é de ", 2026 - idade2, " anos \n")
    escreva ("A diferenca de idades é de ", idade2 - idade1, " anos")
    


  }
}
