programa {
  funcao inicio() {
    real valorAlto = 11.50
    real valorBaixo = 1.50
    real diferenca


    escreva ("O valor mais alto é de R$", valorAlto , "o valor mais baixo é de R$", valorBaixo, "\n")

    diferenca = valorAlto - valorBaixo

    escreva ("A diferença entre o valor mais alto e o valor mais baixo é de R$", diferenca)
  }
}
