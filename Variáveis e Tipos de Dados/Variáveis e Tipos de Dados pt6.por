programa {
  funcao inicio() {
    inteiro numero1 = 1
    inteiro numero2 = 2
    inteiro aux

    escreva ("Em ordem os números são :", numero1, " e ", numero2,"\n")
   

    aux = numero1
    numero1 = numero2
    numero2 = aux

    escreva ("De forma inversa os números são: ", numero1," e ", numero2)
  }
}
