programa {
  funcao inicio() {
    
    inteiro valor1
    inteiro valor2
    inteiro valor3


    escreva ("Digite o primeiro valor: ")
    leia (valor1)

    escreva ("Digite o segundo valor: ")
    leia (valor2)

    escreva ("Digite o terceiro valor: ")
    leia (valor3)

    escreva ("O primeiro valor é: ", valor1, "\n")
    escreva ("O segundo valor é: ", valor2, "\n")
    escreva ("O terceiro valor é: ", valor3)

  }
}
