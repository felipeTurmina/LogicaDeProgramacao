programa {
  funcao inicio() {
    inteiro numero = 1
    real valor = 1.5
    caracter letra = 'a'
    cadeia nome = "Felipe"
    logico estaChovendo = falso


    escreva ("Número: ", numero, "\n" )
    escreva ("Valor: ", valor, "\n")
    escreva ("Letra: ", letra, "\n")
    escreva ("Nome: ", nome, "\n")
    escreva ("Está chovendo?", estaChovendo)
  }
}
