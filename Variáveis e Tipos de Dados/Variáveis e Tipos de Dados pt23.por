programa {
  funcao inicio() {

   real metro
   
   escreva ("Digite a distancia em metros: ")
   leia (metro)


   escreva (" o valor em centímetros é: ", metro *100, "\n")
   escreva ("o valor em milímetros é: ", metro *1000, "\n")
   escreva ("o valor em quilômetros é: ", metro /1000, "\n")

  }
}
