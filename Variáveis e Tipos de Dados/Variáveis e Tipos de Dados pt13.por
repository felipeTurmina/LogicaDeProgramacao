programa {
  funcao inicio() {
    real celsius
    real fahrenheit
  


    escreva ("Digite a temperatura em Celsius: ")
    leia (celsius)

fahrenheit = (celsius * 9.0 / 5.0) + 32

    escreva ("A conversão para Fahrenheit é de ", fahrenheit, "\n")
    escreva ("A conversão para Kelvin é de ", celsius + 273.15)
  }
}
