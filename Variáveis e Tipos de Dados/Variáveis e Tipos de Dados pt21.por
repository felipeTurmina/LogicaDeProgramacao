programa {
  funcao inicio() {

   real distancia
   real litros

    escreva ("Digite a distância percorrida em KM: ")
    leia (distancia)

    escreva ("Digite a quantidade de combustivel consumida em litros: ")
    leia (litros)


    escreva ("O consumo médio foi de ", distancia / litros, " litros por km")
  }
}
